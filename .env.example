# =============================================
# SignBridge — Environment Configuration Template
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================

# ── General ──────────────────────────────────
APP_NAME=signbridge
LOG_LEVEL=INFO

# ── Backend (FastAPI) ───────────────────────
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ML model path (mounted into the container at /app/ml/models)
MODEL_PATH=/app/ml/models
DEMO_ASSETS_PATH=./frontend/public/demo-assets

# Comma-separated CORS origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000,https://signbridge.example.com

# High-frequency gesture list for offline mode
HIGH_FREQUENCY_GESTURES=hello,yes,no,thanks,please,sorry,love,happy,sad

# ── Frontend (Next.js) ──────────────────────
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_TELEMETRY_DISABLED=1
FRONTEND_PORT=3000

# ── Nginx ───────────────────────────────────
NGINX_PORT=80
NGINX_ENV=production

# ── Deployment / CI-CD Secrets ──────────────
# Docker Hub (used by GitHub Actions)
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=<SECRET_04dabab9>ghub_password_or_token

# Staging server (SSH access)
STAGING_HOST=your-staging-server.com
STAGING_USER=deploy
STAGING_SSH_KEY=

# Production server (SSH access)
PROD_HOST=your-prod-server.com
PROD_USER=deploy
PROD_SSH_KEY=<SECRET_c302ca76> Optional: AI / Translation extras ───────
# OPENAI_API_KEY=sk-
# SUMMARIZATION_ENABLED=false
